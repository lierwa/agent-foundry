PORT=4000
# Select `durable` to persist tasks in Postgres and memory in Redis.
AGENT_FOUNDRY_STORE_MODE=in-memory
# Matches `infra/docker-compose.yml` Postgres defaults.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_foundry
# Matches `infra/docker-compose.yml` Redis defaults.
REDIS_URL=redis://localhost:6379
