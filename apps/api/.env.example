# API 服务监听端口。
# 本地开发默认用 4000；如果端口冲突，可以改成别的值。
PORT=4000

# Runtime 存储模式。
# in-memory: 纯内存模式，重启后任务数据会丢失，适合本地快速开发。
# durable: 持久化模式，需要额外配置 DATABASE_URL 和 REDIS_URL。
AGENT_FOUNDRY_STORE_MODE=in-memory

# 豆包 provider 的 API Key。
# 这里只放密钥；模型名、baseUrl、provider 等固定应用配置在 apps/api/src/model-catalog.ts 里维护。
DOUBAO_API_KEY=your_doubao_key

# 千问 provider 的 API Key。
# 同样只放密钥；具体模型目录在 apps/api/src/model-catalog.ts 里维护。
QWEN_API_KEY=your_qwen_key
